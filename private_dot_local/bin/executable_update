#!/usr/bin/env bash

confirm() {
    local prompt="$1"
    read -r -p "$prompt [Y/n] " response
    case "$response" in
        [nN]*) return 1 ;;
        *) return 0 ;;
    esac
}

without_pager() {
    GIT_PAGER=cat PAGER=cat LESS=FRX "$@"
}

prepare_git_repo_for_pull() {
    local repo="$1"
    local upstream
    local file
    local backup_dir

    git -C "$repo" rev-parse --is-inside-work-tree > /dev/null 2>&1 || return 0
    git -C "$repo" fetch --prune || return 1
    upstream=$(git -C "$repo" rev-parse --abbrev-ref --symbolic-full-name "@{u}" 2>/dev/null) || return 0

    git -C "$repo" ls-files --others --exclude-standard -z | while IFS= read -r -d '' file; do
        if git -C "$repo" cat-file -e "$upstream:$file" 2>/dev/null; then
            backup_dir="$repo/.update-untracked-backup/$(date +%Y%m%d%H%M%S)"
            mkdir -p "$backup_dir/$(dirname "$file")"
            mv "$repo/$file" "$backup_dir/$file"
            echo "Moved untracked file that would block update: $file"
            echo "  backup: ${backup_dir#$repo/}/$file"
        fi
    done
}

OS_ID=$(. /etc/os-release 2>/dev/null && echo "$ID" || echo "unknown")

case "$OS_ID" in
    arch)
        echo "Pending system updates:"
        if command -v yay > /dev/null 2>&1; then
            yay -Qu
            confirm "Update system?" && yay --noconfirm --answerclean None --answerdiff None --answeredit None --answerupgrade All
        else
            sudo pacman -Qu
            confirm "Update system?" && sudo pacman -Syu --noconfirm
        fi
        ;;
    ubuntu)
        sudo apt-get update -y
        echo "Pending system updates:"
        apt list --upgradable 2>/dev/null | grep -v "^Listing"
        confirm "Update system?" && sudo apt-get upgrade -y

        if command -v cargo-install-update > /dev/null 2>&1; then
            confirm "Update cargo packages?" && cargo install-update -a --yes
        fi

        FZF_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/fzf"
        if [ -d "$FZF_DIR/.git" ]; then
            if confirm "Update fzf?"; then
                git -C "$FZF_DIR" fetch --depth 1 origin
                git -C "$FZF_DIR" reset --hard FETCH_HEAD
                "$FZF_DIR/install" --bin
            fi
        fi

        if command -v lazydocker > /dev/null 2>&1; then
            if confirm "Update lazydocker?"; then
                LD_VERSION=$(curl -s https://api.github.com/repos/jesseduffield/lazydocker/releases/latest \
                    | grep '"tag_name"' | sed 's/.*"v\([^"]*\)".*/\1/')
                LD_TARBALL="/tmp/lazydocker.tar.gz"
                curl -L -o "$LD_TARBALL" \
                    "https://github.com/jesseduffield/lazydocker/releases/download/v${LD_VERSION}/lazydocker_${LD_VERSION}_Linux_x86_64.tar.gz"
                tar -xzf "$LD_TARBALL" -C "$HOME/.local/bin" lazydocker
                rm -f "$LD_TARBALL"
            fi
        fi

        if command -v nvim > /dev/null 2>&1; then
            if confirm "Update neovim?"; then
                NEOVIM_TARBALL="/tmp/nvim-linux-x86_64.tar.gz"
                curl -L -o "$NEOVIM_TARBALL" "https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz"
                sudo rm -rf /opt/nvim-linux-x86_64
                sudo tar -C /opt -xzf "$NEOVIM_TARBALL"
                rm -f "$NEOVIM_TARBALL"
            fi
        fi
        ;;
    *)
        echo "Unsupported OS: $OS_ID"
        exit 1
        ;;
esac

ZINIT_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git"
if [ -f "$ZINIT_DIR/zinit.zsh" ]; then
    if confirm "Update zinit and plugins?"; then
        prepare_git_repo_for_pull "$ZINIT_DIR" && without_pager zsh -ic "zinit self-update; zinit update --quiet --no-pager --all"
    fi
fi

if command -v jvim > /dev/null 2>&1; then
    if confirm "Update jvim plugins?"; then
        without_pager env NVIM_APPNAME=jvim jvim --headless "+Lazy! update" +qa
        without_pager env NVIM_APPNAME=jvim jvim --headless "+MasonToolsUpdateSync" +qa
    fi
fi
